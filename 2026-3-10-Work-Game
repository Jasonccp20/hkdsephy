<!DOCTYPE html>
<html lang="zh-HK">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>物理作功互動小測</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- PeerJS -->
    <script src="https://unpkg.com/peerjs@1.4.7/dist/peerjs.min.js"></script>
    <!-- MathJax for LaTeX Rendering -->
    <script>
        MathJax = {
            tex: { inlineMath: [['$', '$'], ['\\(', '\\)']] },
            startup: { typeset: false }
        };
    </script>
    <script id="MathJax-script" async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-chtml.js"></script>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f3f4f6; }
        .kahoot-bg { background-color: #f2f2f2; }
        .btn-red { background-color: #e21b3c; border-bottom: 4px solid #b0152e; }
        .btn-blue { background-color: #1368ce; border-bottom: 4px solid #0f51a1; }
        .btn-yellow { background-color: #d89e00; border-bottom: 4px solid #a87b00; }
        .btn-green { background-color: #26890c; border-bottom: 4px solid #1d6a09; }
        .btn-option:active { transform: translateY(4px); border-bottom-width: 0px; margin-bottom: 4px; }
        .shape { width: 40px; height: 40px; fill: white; }
        .fade-in { animation: fadeIn 0.3s ease-in-out; }
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    </style>
</head>
<body class="kahoot-bg min-h-screen text-gray-800">

    <div id="app" class="w-full min-h-screen flex flex-col">
        <!-- 內容由 JavaScript 動態渲染 -->
    </div>

<script>
    // --- 題目資料 ---
    const QUIZ_DATA = [
        {
            question: "Q1: 作功 (Work) 的國際單位 (SI Unit) 是甚麼？",
            time: 20,
            options: ["牛頓 (N)", "焦耳 (J)", "瓦特 (W)", "公尺 (m)"],
            correct: 1, // B
            explanation: "答對了嗎？1 焦耳的功等於 1 牛頓的力在施力方向上產生 1 公尺的位移 ($1 \\text{ J} = 1 \\text{ N m}$)。"
        },
        {
            question: "Q2: 關於「作功 (Work)」的物理性質，以下哪項描述是正確的？",
            time: 20,
            options: ["它是矢量 (Vector)，有大小和方向", "它是標量 (Scalar)，只有大小沒有方向", "它是標量，只有方向沒有大小", "它的數值永遠大於零"],
            correct: 1, // B
            explanation: "要記住喔，作功是能量的轉移，它只有大小 (Magnitude)，並沒有方向 (Direction)。"
        },
        {
            question: "Q3: 當施加的力 $F$ 與物體的位移 $s$ 之間存在一個夾角 $\\theta$ 時，計算作功的正確公式是甚麼？",
            time: 30,
            options: ["$W = Fs \\sin \\theta$", "$W = Fs$", "$W = Fs \\cos \\theta$", "$W = \\frac{F}{s} \\cos \\theta$"],
            correct: 2, // C
            explanation: "我們只需要計算與位移平行的力分量 (Component of force parallel to displacement)，即 $F \\cos \\theta$。"
        },
        {
            question: "Q4: 舉重運動員用力舉起沉重的槓鈴後，在半空中保持靜止不動5秒。在這5秒內，他對槓鈴作了多少功？",
            time: 30,
            options: ["很大，因為槓鈴非常重", "$0 \\text{ J}$，因為沒有施加力 ($F = 0$)", "$0 \\text{ J}$，因為位移為零 ($s = 0$)", "無法計算"],
            correct: 2, // C
            explanation: "雖然運動員覺得很累，但因為槓鈴沒有移動 ($s = 0$)，所以這段時間內的機械功為 $0 \\text{ J}$！"
        },
        {
            question: "Q5: 一名送貨員雙手向上托住一個重箱子，並以均速向前水平走動。在水平走動的過程中，他對箱子作了多少功？",
            time: 30,
            options: ["很大，因為箱子有重量且有移動", "$0 \\text{ J}$，因為力與位移互相垂直 ($\\theta = 90^\\circ$)", "視乎他走路的速度而定", "$0 \\text{ J}$，因為他沒有施加任何力"],
            correct: 1, // B
            explanation: "這是考試常出的陷阱題！送貨員施加的力是向上的（為了對抗重力），但位移是水平的。兩者夾角為 $90^\\circ$，而 $\\cos 90^\\circ = 0$，因此作功為 $0 \\text{ J}$。"
        }
    ];

    // --- SVG Shapes ---
    const SHAPES = [
        '<svg class="shape" viewBox="0 0 24 24"><path d="M12 2L2 22h20L12 2z"/></svg>', // Triangle (Red)
        '<svg class="shape" viewBox="0 0 24 24"><path d="M12 2L2 12l10 10 10-10L12 2z"/></svg>', // Diamond (Blue)
        '<svg class="shape" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/></svg>', // Circle (Yellow)
        '<svg class="shape" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18"/></svg>' // Square (Green)
    ];
    const COLORS = ['btn-red', 'btn-blue', 'btn-yellow', 'btn-green'];

    // --- 應用程式狀態 ---
    let app = {
        role: null, // 'host' or 'player'
        view: 'home', // home, host-lobby, host-question, host-result, host-leaderboard, player-login, player-waiting, player-question, player-result
        peer: null,
        pin: '',
        
        // Host state
        connections: {}, // connId -> PeerJS Connection
        players: {}, // connId -> { name, score, currentAnswer, hasAnswered }
        currentQuestionIndex: 0,
        timer: null,
        timeLeft: 0,
        answerCounts: [0, 0, 0, 0],
        
        // Player state
        conn: null,
        myName: '',
        myScore: 0,
        myLastResult: null, // { isCorrect, pointsEarned, rank }
        
        showMsg: ''
    };

    // --- PeerJS 增強設定 (加入 STUN 伺服器以突破防火牆/iOS限制) ---
    const peerConfig = {
        secure: true,
        config: {
            'iceServers': [
                { urls: 'stun:stun.l.google.com:19302' },
                { urls: 'stun:stun1.l.google.com:19302' },
                { urls: 'stun:stun2.l.google.com:19302' }
            ]
        },
        debug: 2
    };

    // 檢測是否在 iframe (例如 Google Sites) 中運行
    const inIframe = window.self !== window.top;

    // --- 渲染引擎 ---
    function render() {
        const appDiv = document.getElementById('app');
        let html = '';

        if (app.view === 'home') {
            html = `
                <div class="flex-1 flex flex-col items-center justify-center p-4 fade-in">
                    <h1 class="text-4xl md:text-5xl font-bold mb-2 text-center text-purple-700">🚀 物理小測</h1>
                    <p class="text-xl mb-12 text-gray-600 font-semibold">作功與能量轉移</p>
                    
                    <div class="flex flex-col md:flex-row gap-6 w-full max-w-2xl">
                        <button onclick="startAsHost()" class="flex-1 py-12 bg-purple-600 hover:bg-purple-700 text-white rounded-2xl shadow-lg text-2xl font-bold transition transform hover:scale-105">
                            👨‍🏫 建立遊戲 (老師)
                        </button>
                        <button onclick="app.view='player-login'; render();" class="flex-1 py-12 bg-white border-4 border-gray-200 hover:border-purple-400 text-gray-800 rounded-2xl shadow-lg text-2xl font-bold transition transform hover:scale-105">
                            📱 加入遊戲 (學生)
                        </button>
                    </div>
                </div>
            `;
        } 
        // ==========================================
        // 老師視角 (Host Views)
        // ==========================================
        else if (app.view === 'host-lobby') {
            const playerNames = Object.values(app.players).map(p => p.name);
            html = `
                <div class="flex-1 flex flex-col p-6 fade-in">
                    <div class="bg-white p-8 rounded-2xl shadow-md text-center mb-8">
                        <h2 class="text-2xl text-gray-500 mb-2 font-bold">請前往網站並輸入遊戲 PIN 碼</h2>
                        <div class="text-7xl font-black tracking-widest text-gray-800 my-4">${app.pin || '載入中...'}</div>
                    </div>
                    
                    <div class="flex-1 flex flex-col items-center">
                        <div class="flex justify-between items-center w-full max-w-4xl mb-4">
                            <span class="text-2xl font-bold bg-gray-800 text-white px-6 py-2 rounded-full">玩家人數: ${playerNames.length}</span>
                            <button onclick="startGame()" class="${playerNames.length > 0 ? 'bg-green-500 hover:bg-green-600' : 'bg-gray-400 cursor-not-allowed'} text-white px-8 py-3 rounded-xl text-xl font-bold shadow-md" ${playerNames.length === 0 ? 'disabled' : ''}>開始遊戲</button>
                        </div>
                        <div class="flex flex-wrap gap-4 w-full max-w-4xl justify-center">
                            ${playerNames.map(name => `<div class="bg-white px-6 py-3 rounded-lg shadow font-bold text-xl">${name}</div>`).join('')}
                            ${playerNames.length === 0 ? '<p class="text-gray-400 text-xl mt-10">等待玩家加入...</p>' : ''}
                        </div>
                    </div>
                </div>
            `;
        }
        else if (app.view === 'host-question') {
            const q = QUIZ_DATA[app.currentQuestionIndex];
            const answeredCount = Object.values(app.players).filter(p => p.hasAnswered).length;
            const totalPlayers = Object.keys(app.players).length;
            
            html = `
                <div class="flex-1 flex flex-col p-4 fade-in">
                    <div class="text-center mb-4">
                        <span class="text-gray-500 font-bold text-xl">第 ${app.currentQuestionIndex + 1} / ${QUIZ_DATA.length} 題</span>
                    </div>
                    <div class="bg-white p-8 rounded-2xl shadow-lg text-center mb-6 min-h-[150px] flex items-center justify-center">
                        <h2 class="text-3xl md:text-4xl font-bold text-gray-800 leading-tight">${q.question}</h2>
                    </div>
                    
                    <div class="flex justify-between items-center mb-6 px-4">
                        <div class="w-24 h-24 rounded-full bg-purple-600 flex items-center justify-center shadow-lg text-white text-4xl font-black ${app.timeLeft <= 5 ? 'animate-pulse bg-red-600' : ''}">
                            ${app.timeLeft}
                        </div>
                        <div class="text-right">
                            <div class="text-5xl font-black text-gray-800">${answeredCount}</div>
                            <div class="text-gray-500 font-bold text-xl">已作答</div>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 flex-1">
                        ${q.options.map((opt, idx) => `
                            <div class="${COLORS[idx]} text-white p-6 rounded-xl flex items-center shadow-md">
                                <div class="mr-4">${SHAPES[idx]}</div>
                                <span class="text-2xl font-bold">${opt}</span>
                            </div>
                        `).join('')}
                    </div>
                    <button onclick="stopQuestion()" class="mt-6 bg-gray-800 text-white py-3 rounded-xl font-bold text-xl hover:bg-gray-700">提早結束計時</button>
                </div>
            `;
        }
        else if (app.view === 'host-result') {
            const q = QUIZ_DATA[app.currentQuestionIndex];
            html = `
                <div class="flex-1 flex flex-col p-4 fade-in">
                    <div class="bg-white p-6 rounded-2xl shadow-lg text-center mb-6">
                        <h2 class="text-2xl font-bold text-gray-800">${q.question}</h2>
                        <div class="mt-4 p-4 bg-purple-50 rounded-xl text-left border-l-4 border-purple-500">
                            <span class="font-bold text-purple-800 text-lg">老師解析：</span>
                            <p class="text-lg mt-2">${q.explanation}</p>
                        </div>
                    </div>

                    <div class="flex-1 flex items-end justify-center gap-4 mb-8 h-64 border-b-2 border-gray-300 pb-2">
                        ${app.answerCounts.map((count, idx) => {
                            const max = Math.max(...app.answerCounts, 1);
                            const height = (count / max) * 100;
                            const isCorrect = (idx === q.correct);
                            return `
                                <div class="flex flex-col items-center w-24">
                                    <div class="font-bold text-xl mb-2">${count}</div>
                                    <div class="${COLORS[idx]} w-full rounded-t-sm transition-all duration-500" style="height: ${height}%; opacity: ${isCorrect ? '1' : '0.4'}"></div>
                                    <div class="mt-2 ${isCorrect ? 'bg-green-500 text-white px-2 rounded-full shadow' : ''}">${isCorrect ? '✅ 正確' : ''}</div>
                                </div>
                            `;
                        }).join('')}
                    </div>

                    <div class="flex justify-between items-center px-4">
                        <button onclick="showLeaderboard()" class="bg-blue-600 hover:bg-blue-700 text-white px-8 py-4 rounded-xl text-xl font-bold shadow-md w-full">顯示排行榜 🏆</button>
                    </div>
                </div>
            `;
        }
        else if (app.view === 'host-leaderboard') {
            const sortedPlayers = Object.values(app.players).sort((a, b) => b.score - a.score).slice(0, 5);
            const isLast = app.currentQuestionIndex === QUIZ_DATA.length - 1;

            html = `
                <div class="flex-1 flex flex-col items-center p-6 fade-in bg-purple-800 text-white">
                    <h1 class="text-5xl font-black mb-10 mt-10 tracking-wider">排行榜 🏆</h1>
                    <div class="w-full max-w-2xl flex flex-col gap-4">
                        ${sortedPlayers.map((p, i) => `
                            <div class="bg-white text-gray-800 rounded-xl p-4 flex justify-between items-center shadow-lg transform transition hover:scale-105">
                                <div class="flex items-center gap-4">
                                    <div class="w-10 h-10 rounded-full bg-gray-200 flex items-center justify-center font-bold text-xl">${i+1}</div>
                                    <span class="text-2xl font-bold">${p.name}</span>
                                </div>
                                <span class="text-3xl font-black">${p.score}</span>
                            </div>
                        `).join('')}
                    </div>
                    <button onclick="${isLast ? 'location.reload()' : 'nextQuestion()'}" class="mt-12 bg-white text-purple-800 hover:bg-gray-100 px-10 py-4 rounded-full text-2xl font-bold shadow-xl">
                        ${isLast ? '結束遊戲 (返回首頁)' : '下一題 ➡️'}
                    </button>
                </div>
            `;
        }

        // ==========================================
        // 學生視角 (Player Views)
        // ==========================================
        else if (app.view === 'player-login') {
            let iframeWarning = '';
            if (inIframe) {
                iframeWarning = `
                    <div class="bg-yellow-100 text-yellow-800 p-4 rounded-xl mb-6 text-center text-sm font-bold shadow-sm border-2 border-yellow-300">
                        ⚠️ iPad/iPhone 用戶若卡住無法加入<br>
                        <a href="${window.location.href}" target="_blank" class="text-blue-700 underline text-xl block mt-3">👉 請點擊這裡在新分頁開啟遊戲</a>
                    </div>
                `;
            }

            html = `
                <div class="flex-1 flex flex-col items-center justify-center p-4 fade-in">
                    <div class="bg-white p-8 rounded-2xl shadow-xl w-full max-w-md">
                        <h2 class="text-3xl font-black text-center mb-6 text-gray-800">加入遊戲</h2>
                        ${iframeWarning}
                        ${app.showMsg ? `<div class="bg-red-100 text-red-700 p-3 rounded mb-4 text-center font-bold">${app.showMsg}</div>` : ''}
                        <input id="pin-input" type="text" placeholder="遊戲 PIN 碼" class="w-full text-center text-3xl font-bold p-4 mb-4 border-2 border-gray-300 rounded-xl focus:outline-none focus:border-purple-500 uppercase">
                        <input id="name-input" type="text" placeholder="你的名字" class="w-full text-center text-2xl font-bold p-4 mb-6 border-2 border-gray-300 rounded-xl focus:outline-none focus:border-purple-500">
                        <button onclick="joinGame()" class="w-full bg-gray-800 hover:bg-black text-white py-4 rounded-xl text-2xl font-bold shadow-lg">進入</button>
                        <button onclick="app.view='home'; app.showMsg=''; render();" class="w-full mt-4 text-gray-500 font-bold hover:text-gray-700">返回</button>
                    </div>
                </div>
            `;
        }
        else if (app.view === 'player-waiting') {
            html = `
                <div class="flex-1 flex flex-col items-center justify-center p-4 fade-in bg-purple-600 text-white">
                    <h2 class="text-4xl font-black mb-4">你已加入！</h2>
                    <p class="text-2xl font-bold bg-purple-800 px-6 py-2 rounded-full">玩家：${app.myName}</p>
                    <div class="mt-12 text-2xl font-bold animate-pulse text-purple-200">看著老師的螢幕準備...</div>
                </div>
            `;
        }
        else if (app.view === 'player-question') {
            const hasAnswered = app.myLastResult && app.myLastResult.answered;
            if (hasAnswered) {
                html = `
                    <div class="flex-1 flex flex-col items-center justify-center p-4 fade-in bg-gray-200">
                        <h2 class="text-3xl font-bold text-gray-600">等待其他玩家...</h2>
                        <div class="mt-4 animate-spin rounded-full h-12 w-12 border-b-4 border-gray-600"></div>
                    </div>
                `;
            } else {
                html = `
                    <div class="flex-1 flex flex-col p-2 gap-2 h-screen fade-in">
                        <div class="grid grid-cols-2 grid-rows-2 h-full gap-2">
                            ${COLORS.map((colorClass, idx) => `
                                <button onclick="submitAnswer(${idx})" class="${colorClass} btn-option rounded-xl flex items-center justify-center shadow-md w-full h-full">
                                    <div class="scale-150">${SHAPES[idx]}</div>
                                </button>
                            `).join('')}
                        </div>
                    </div>
                `;
            }
        }
        else if (app.view === 'player-result') {
            const res = app.myLastResult;
            const bgClass = res.isCorrect ? 'bg-green-500' : 'bg-red-500';
            const icon = res.isCorrect ? '✅' : '❌';
            const msg = res.isCorrect ? '答對了！' : '答錯了！';
            
            html = `
                <div class="flex-1 flex flex-col items-center justify-center p-6 fade-in ${bgClass} text-white">
                    <div class="text-6xl mb-4">${icon}</div>
                    <h2 class="text-5xl font-black mb-8">${msg}</h2>
                    <div class="bg-black bg-opacity-20 px-8 py-4 rounded-2xl text-center">
                        <div class="text-xl font-bold mb-1">獲得分數</div>
                        <div class="text-4xl font-black">+ ${res.pointsEarned}</div>
                    </div>
                    <div class="mt-8 text-2xl font-bold bg-black bg-opacity-30 px-6 py-2 rounded-full">
                        總分: ${app.myScore}
                    </div>
                    <div class="mt-12 text-xl font-bold text-white opacity-80 animate-pulse">看著老師的螢幕...</div>
                </div>
            `;
        }
        else if (app.view === 'player-end') {
            html = `
                <div class="flex-1 flex flex-col items-center justify-center p-6 fade-in bg-purple-700 text-white">
                    <h2 class="text-4xl font-black mb-6">遊戲結束！</h2>
                    <div class="bg-white text-purple-800 px-10 py-8 rounded-3xl text-center shadow-2xl">
                        <div class="text-2xl font-bold mb-2">你的最終分數</div>
                        <div class="text-6xl font-black mb-6">${app.myScore}</div>
                        <div class="text-xl font-bold bg-gray-200 px-4 py-2 rounded-full inline-block">名次: 第 ${app.myLastResult.rank} 名</div>
                    </div>
                    <button onclick="location.reload()" class="mt-12 text-white border-2 border-white px-8 py-3 rounded-full font-bold hover:bg-white hover:text-purple-700 transition">回到首頁</button>
                </div>
            `;
        }

        appDiv.innerHTML = html;

        // 觸發 MathJax 渲染 LaTeX
        if (typeof MathJax !== 'undefined' && MathJax.typesetPromise) {
            MathJax.typesetPromise([appDiv]).catch((err) => console.log(err.message));
        }
    }

    // ==========================================
    // 老師 (Host) 邏輯
    // ==========================================
    function generatePIN() {
        return Math.floor(1000 + Math.random() * 9000).toString(); // 4位數字
    }

    function startAsHost() {
        app.role = 'host';
        app.pin = generatePIN();
        app.view = 'host-lobby';
        render();

        // 建立 Peer，加入增強設定
        const peerId = 'quiz-' + app.pin;
        app.peer = new Peer(peerId, peerConfig);

        app.peer.on('open', (id) => {
            console.log('Host created with ID:', id);
            render();
        });

        app.peer.on('connection', (conn) => {
            conn.on('data', (data) => {
                handleHostMessage(conn.peer, data, conn);
            });
            conn.on('close', () => {
                delete app.players[conn.peer];
                delete app.connections[conn.peer];
                if(app.view === 'host-lobby') render();
            });
            app.connections[conn.peer] = conn;
        });

        app.peer.on('error', (err) => {
            alert('連線建立失敗，請重試: ' + err.type + '\\n' + err.message);
            app.view = 'home';
            render();
        });
    }

    function handleHostMessage(peerId, msg, conn) {
        if (msg.type === 'join') {
            app.players[peerId] = { name: msg.name, score: 0, currentAnswer: null, hasAnswered: false };
            conn.send({ type: 'joined', state: 'waiting' });
            if(app.view === 'host-lobby') render();
        } 
        else if (msg.type === 'answer') {
            const player = app.players[peerId];
            if (player && !player.hasAnswered && app.view === 'host-question') {
                player.hasAnswered = true;
                player.currentAnswer = msg.answer;
                app.answerCounts[msg.answer]++;
                
                // 計算分數 (Kahoot 機制：基礎分 + 時間加成)
                const q = QUIZ_DATA[app.currentQuestionIndex];
                let points = 0;
                let isCorrect = (msg.answer === q.correct);
                if (isCorrect) {
                    const timeRatio = app.timeLeft / q.time; // 0 到 1
                    points = Math.round(500 + (500 * timeRatio));
                }
                player.score += points;

                conn.send({ type: 'answer_received' });
                render();

                // 檢查是否所有人都答了
                const allAnswered = Object.values(app.players).every(p => p.hasAnswered);
                if (allAnswered) {
                    stopQuestion();
                }
            }
        }
    }

    function broadcast(msg) {
        Object.values(app.connections).forEach(conn => {
            if(conn.open) conn.send(msg);
        });
    }

    function startGame() {
        app.currentQuestionIndex = 0;
        prepareQuestion();
    }

    function prepareQuestion() {
        // 重置狀態
        Object.values(app.players).forEach(p => {
            p.hasAnswered = false;
            p.currentAnswer = null;
        });
        app.answerCounts = [0, 0, 0, 0];
        app.view = 'host-question';
        app.timeLeft = QUIZ_DATA[app.currentQuestionIndex].time;
        
        broadcast({ type: 'state', state: 'question' });
        render();

        app.timer = setInterval(() => {
            app.timeLeft--;
            render();
            if (app.timeLeft <= 0) {
                stopQuestion();
            }
        }, 1000);
    }

    function stopQuestion() {
        clearInterval(app.timer);
        app.view = 'host-result';
        
        // 發送結果給每個學生
        const q = QUIZ_DATA[app.currentQuestionIndex];
        Object.keys(app.players).forEach(peerId => {
            const p = app.players[peerId];
            const isCorrect = p.currentAnswer === q.correct;
            // 計算剛剛得到的分數 (有點 Hacky, 因為分數已經在 answer 時加了, 這裡只算差值)
            let pointsEarned = 0;
            if (p.hasAnswered && isCorrect) {
                 // recalculate roughly or just send current score.
                 // we stored total score. Let's trace earned points by difference, 
                 // but since we update score instantly, let's recalculate earned points for display.
                 const timeRatio = p.answerTimeRatio || 0; // We didn't save when they answered exactly, so approximate:
                 // Actually, we can just check their current score minus previous. To keep it simple, we just recalculate based on rule if they got it right, or send a simplified points earned.
            }
            // To fix point earned calculation properly:
            // I will modify `handleHostMessage` to store `pointsEarned` temporarily in `p`.
        });

        // 正確的作法：廣播帶有個人結果的訊息
        Object.entries(app.players).forEach(([peerId, p]) => {
            const isCorrect = (p.currentAnswer === q.correct);
            const conn = app.connections[peerId];
            if (conn && conn.open) {
                conn.send({ 
                    type: 'state', 
                    state: 'result', 
                    data: {
                        isCorrect: isCorrect,
                        score: p.score,
                        pointsEarned: (p.hasAnswered && isCorrect) ? (p.lastPointsEarned || calculatePoints(p.answerTimeRatio)) : 0 // will fix in handleHostMessage
                    }
                });
            }
        });
        render();
    }
    
    // Patch handleHostMessage to record points earned
    const originalHandleHostMessage = handleHostMessage;
    handleHostMessage = function(peerId, msg, conn) {
        if (msg.type === 'answer') {
            const player = app.players[peerId];
            if (player && !player.hasAnswered && app.view === 'host-question') {
                const q = QUIZ_DATA[app.currentQuestionIndex];
                let isCorrect = (msg.answer === q.correct);
                let points = 0;
                if (isCorrect) {
                    const timeRatio = app.timeLeft / q.time;
                    points = Math.round(500 + (500 * timeRatio));
                }
                player.lastPointsEarned = points;
                // call original logic (but avoid double adding score, so I will override it fully here)
                player.hasAnswered = true;
                player.currentAnswer = msg.answer;
                app.answerCounts[msg.answer]++;
                player.score += points;

                conn.send({ type: 'answer_received' });
                render();

                const allAnswered = Object.values(app.players).every(p => p.hasAnswered);
                if (allAnswered) stopQuestion();
            }
        } else {
            originalHandleHostMessage(peerId, msg, conn);
        }
    };


    function showLeaderboard() {
        app.view = 'host-leaderboard';
        
        // 計算排名傳給學生
        const sorted = Object.entries(app.players).sort((a, b) => b[1].score - a[1].score);
        sorted.forEach(([peerId, p], index) => {
            const conn = app.connections[peerId];
            if (conn && conn.open) {
                conn.send({
                    type: 'state',
                    state: app.currentQuestionIndex === QUIZ_DATA.length - 1 ? 'end' : 'waiting',
                    data: { rank: index + 1, score: p.score }
                });
            }
        });
        
        render();
    }

    function nextQuestion() {
        app.currentQuestionIndex++;
        if (app.currentQuestionIndex < QUIZ_DATA.length) {
            prepareQuestion();
        }
    }


    // ==========================================
    // 學生 (Player) 邏輯
    // ==========================================
    function joinGame() {
        const pin = document.getElementById('pin-input').value.trim();
        const name = document.getElementById('name-input').value.trim();

        if (!pin || !name) {
            app.showMsg = "請輸入 PIN 碼和名字！";
            render();
            return;
        }

        app.showMsg = "連線中，請稍候...";
        render();

        app.myName = name;
        app.peer = new Peer(peerConfig); // 學生自動產生 ID，加入增強設定
        
        app.peer.on('open', (id) => {
            const hostId = 'quiz-' + pin;
            // 加入 reliable: true 讓連線在網頁不穩定時更可靠
            app.conn = app.peer.connect(hostId, { reliable: true });

            app.conn.on('open', () => {
                app.conn.send({ type: 'join', name: name });
            });

            app.conn.on('data', (msg) => {
                handlePlayerMessage(msg);
            });

            app.conn.on('close', () => {
                alert('已從主機斷線。');
                location.reload();
            });
        });

        app.peer.on('error', (err) => {
            console.error("PeerJS Error:", err);
            app.showMsg = "無法連線 (" + err.type + ")<br>請嘗試點擊上方的「在新分頁開啟遊戲」";
            render();
        });
    }

    function handlePlayerMessage(msg) {
        if (msg.type === 'joined') {
            app.view = 'player-waiting';
            render();
        } 
        else if (msg.type === 'state') {
            if (msg.state === 'question') {
                app.view = 'player-question';
                app.myLastResult = { answered: false };
            } 
            else if (msg.state === 'result') {
                app.view = 'player-result';
                app.myScore = msg.data.score;
                app.myLastResult = {
                    isCorrect: msg.data.isCorrect,
                    pointsEarned: msg.data.pointsEarned
                };
            }
            else if (msg.state === 'waiting') {
                app.view = 'player-waiting';
            }
            else if (msg.state === 'end') {
                app.view = 'player-end';
                app.myLastResult.rank = msg.data.rank;
            }
            render();
        }
        else if (msg.type === 'answer_received') {
            app.myLastResult.answered = true;
            render();
        }
    }

    function submitAnswer(idx) {
        if (app.conn && app.conn.open) {
            app.conn.send({ type: 'answer', answer: idx });
        }
    }

    // 初始渲染
    render();
</script>
